{
  "rewrites": [
    {
      "source": "/uefa-api/:path*",
      "destination": "https://match.uefa.com/:path*"
    },
    {
      "source": "/fifa-api/:path*",
      "destination": "https://api.fifa.com/:path*"
    },
    {
      "source": "/ligue1-api/:path*",
      "destination": "https://ma-api.ligue1.fr/:path*"
    },
    {
      "source": "/pl-api/:path*",
      "destination": "https://sdp-prem-prod.premier-league-prod.pulselive.com/:path*"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https://flagcdn.com https://*.uefa.com https://upload.wikimedia.org https://api.fifa.com https://resources.premierleague.com https://s3.eu-west-1.amazonaws.com https://s3.eu-west-3.amazonaws.com data:; font-src 'self'; connect-src 'self' https://match.uefa.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        }
      ]
    }
  ]
}
